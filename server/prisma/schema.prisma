generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  phone     String?  @unique
  password  String
  nickname  String?
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes         Note[]
  reviewRecords ReviewRecord[]

  @@map("users")
}

model Note {
  id          String   @id @default(cuid())
  title       String
  contentType String   @default("text") // pdf, docx, text
  content     String?  @db.LongText
  filePath    String?
  aiSummary   String?  @db.Text
  tags        Json     @default("[]")
  status      String   @default("analyzing") // analyzing, completed, failed
  syncedFrom  String?  // 记录原始上传者 userId（管理员同步笔记时标记来源）
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  knowledgePoints KnowledgePoint[]

  @@map("notes")
}

model KnowledgePoint {
  id          String  @id @default(cuid())
  name        String
  description String? @db.Text
  domain      String?
  mastery     Int     @default(0) // 0-100

  noteId String
  note   Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)

  questions Question[]

  @@map("knowledge_points")
}

model Question {
  id             String  @id @default(cuid())
  questionType   String  @default("choice") // choice, fill
  questionText   String  @db.Text
  options        Json    // choice: 选项数组; fill: 提示信息数组
  correctAnswer  String
  explanation    String  @db.Text
  domain         String?

  knowledgePointId String
  knowledgePoint   KnowledgePoint @relation(fields: [knowledgePointId], references: [id], onDelete: Cascade)

  reviewRecords ReviewRecord[]

  @@map("questions")
}

model ReviewRecord {
  id          String   @id @default(cuid())
  userAnswer  String
  isCorrect   Boolean
  createdAt   DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("review_records")
}
